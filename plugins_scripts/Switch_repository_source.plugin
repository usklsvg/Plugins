#!name = 可莉仓库源切换
#!desc = 用于切换可莉仓库源的插件，以便能够在直连的情况下也能更新仓库资源。此插件和GitHub加速类插件冲突，不可同时启用。可在Gitea、GitLab和GitHub平台之间切换可莉的仓库源。
#!openUrl =
#!author = 可莉🅥[https://gitlab.com/lodepuly/vpn_tool/-/blob/master/README.md]
#!tag = 插件管理
#!system =
#!system_version =
#!loon_version = 3.2.1(745)
#!homepage = https://gitlab.com/lodepuly/vpn_tool/-/blob/master/README.md
#!icon = https://gitlab.com/lodepuly/iconlibrary/-/raw/main/Other_icon/120px/Switch.png
#!select = 仓库源, Gitea - 四网直连, GitLab - 电信联通直连, GitHub - 访问不畅
#!date = 2024-04-21 02:37:51

[Script]
http-request ^https:\/\/raw\.githubusercontent\.com\/luestr\/ProxyResource\/main\/ script-path = https://gitlab.com/lodepuly/vpn_tool/-/raw/master/Resource/Script/Switch_repository_source/Switch_repository_source.js, tag = GitHub换源
http-request ^https:\/\/gitlab\.com\/lodepuly\/vpn_tool\/-\/raw\/master\/ script-path = https://gitlab.com/lodepuly/vpn_tool/-/raw/master/Resource/Script/Switch_repository_source/Switch_repository_source.js, tag = GitLab换源
http-request ^https:\/\/gitea\.com\/latick\/ProxyResource\/raw\/branch\/main\/ script-path = https://gitlab.com/lodepuly/vpn_tool/-/raw/master/Resource/Script/Switch_repository_source/Switch_repository_source.js, tag = Gitea换源

[MitM]
hostname = gitlab.com, raw.githubusercontent.com, gitea.com
