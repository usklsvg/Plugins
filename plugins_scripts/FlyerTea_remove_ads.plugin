#!name = 飞客去广告
#!desc = 移除开屏广告、首页广告、板块广告、帖内广告和我的页面广告。
#!openUrl = https://apps.apple.com/app/id547560608
#!author = 可莉🅥[https://gitlab.com/lodepuly/vpn_tool/-/blob/master/README.md]
#!tag = 去广告
#!system =
#!system_version =
#!loon_version = 3.2.1(745)
