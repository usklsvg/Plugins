#!name = 汽车之家去广告
#!desc = 移除开屏广告、各类广告横幅、各类信息流广告、各类弹窗推广、各类浮窗、我的页面广告。
#!openUrl = https://apps.apple.com/app/id385919493
#!author = 可莉🅥[https://gitlab.com/lodepuly/vpn_tool/-/blob/master/README.md]
#!tag = 去广告
#!system =
#!system_version =
#!loon_version = 3.2.1(749)
#!homepage = https://gitlab.com/lodepuly/vpn_tool/-/blob/master/README.md
#!icon = https://gitlab.com/lodepuly/iconlibrary/-/raw/main/App_icon/120px/AutoHome.png
#!date = 2024-07-17 18:20:06

[Script]
# 首页 - 左上角以旧换新
http-response ^https:\/\/news\.app\.autohome\.com\.cn\/news_v\d+(?:\.\d+){2}\/news\/homenavigation script-path = https://gitlab.com/lodepuly/vpn_tool/-/raw/master/Resource/Script/AutoHome/AutoHome_remove_ads.js, requires-body = true, tag = 精简我的页面

# 我的页面 - 精简精选服务、全部服务、添加我的爱车领券、热门活动
http-response ^https:\/\/(a\.athm\.cn\/)?mobile\.app\.autohome\.com\.cn\/platform\/carserver\/((usercenter\/getservicecards)|(carcard\/allcard)|(carcard\/mycardv\d+)|(carcard\/cards)) script-path = https://gitlab.com/lodepuly/vpn_tool/-/raw/master/Resource/Script/AutoHome/AutoHome_remove_ads.js, requires-body = true, tag = 精简我的页面

# 社区广场 - 广告轮播图
http-response ^https:\/\/(a\.athm\.cn\/)?club\.app\.autohome\.com\.cn\/club_v\d+(?:\.\d+){2}\/club\/index\/businessv\d+ script-path = https://gitlab.com/lodepuly/vpn_tool/-/raw/master/Resource/Script/AutoHome/AutoHome_remove_ads.js, requires-body = true, tag = 社区广场去广告

# 选车 - 直播浮窗
http-response ^https:\/\/(a\.athm\.cn\/)?cars\.app\.autohome\.com\.cn\/carstreaming\/selectcarportal\/reclist script-path = https://gitlab.com/lodepuly/vpn_tool/-/raw/master/Resource/Script/AutoHome/AutoHome_remove_ads.js, requires-body = true, tag = 移除直播浮窗

# 选车 - 新车报价页面直播内容 - 无效
http-response ^https:\/\/(a\.athm\.cn\/)?cars\.app\.autohome\.com\.cn\/carstreaming\/selectcarportal\/seriestopwithtagscard script-path = https://gitlab.com/lodepuly/vpn_tool/-/raw/master/Resource/Script/AutoHome/AutoHome_remove_ads.js, requires-body = true, tag = 移除报价页面直播内容

# 二手车 - 竖版轮播图 - 无效
http-response ^https:\/\/(a\.athm\.cn\/)?apiautoappusc\.che168\.com\/apic\/v\d+\/gethomepagefeed script-path = https://gitlab.com/lodepuly/vpn_tool/-/raw/master/Resource/Script/AutoHome/AutoHome_remove_ads.js, requires-body = true, tag = 移除二手车竖版轮播图

[MitM]
hostname = a.athm.cn, adproxy.autohome.com.cn, apiautoappusc.che168.com, autoapi.autohome.com.cn, cars.app.autohome.com.cn, clientlive.api.autohome.com.cn, club.app.autohome.com.cn, dealer.m.autohome.com.cn, maam.pingan.com.cn, mobile.app.autohome.com.cn, news.app.autohome.com.cn, pcmx.autohome.com.cn
